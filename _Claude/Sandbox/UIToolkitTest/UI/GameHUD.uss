#game-hud {
    flex-grow: 1;
    justify-content: space-between;
}

#top-bar {
    height: 28px;
    background-color: #f5f5f0;
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 8px;
    border-bottom-width: 2px;
    border-bottom-color: #333;
}

#money {
    font-size: 14px;
    -unity-font-style: bold;
    margin-right: 12px;
}

#stage {
    font-size: 14px;
    margin-right: 12px;
}

#progress-bar {
    width: 80px;
    height: 12px;
    background-color: #fff;
    border-width: 2px;
    border-color: #333;
}

#progress-fill {
    width: 40%;
    height: 100%;
    background-color: #333;
}

#menu-btn {
    margin-left: auto;
    width: 28px;
    height: 22px;
    background-color: #f5f5f0;
    border-width: 2px;
    border-color: #333;
    justify-content: space-around;
    align-items: center;
    padding-top: 3px;
    padding-bottom: 3px;
    padding-left: 4px;
    padding-right: 4px;
}

.menu-line {
    width: 100%;
    height: 2px;
    background-color: #333;
}

#bottom-bar {
    height: 40px;
    background-color: #e8e8e0;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 8px;
    padding-right: 8px;
    border-top-width: 2px;
    border-top-color: #333;
}

#key-guides {
    flex-direction: row;
}

.key-guide {
    width: 40px;
    height: 32px;
    border-width: 2px;
    border-color: #333;
    background-color: #fff;
    align-items: center;
    justify-content: center;
    margin-right: 4px;
}

.key-label {
    font-size: 7px;
}

.key-icon {
    font-size: 14px;
}

#action-btn {
    height: 32px;
    padding-left: 10px;
    padding-right: 10px;
    border-width: 2px;
    border-color: #333;
    background-color: #fff;
    flex-direction: row;
    align-items: center;
}

#action-btn > .key-label {
    font-size: 10px;
    color: #555;
    margin-right: 4px;
}

.action-text {
    font-size: 13px;
    -unity-font-style: bold;
}
