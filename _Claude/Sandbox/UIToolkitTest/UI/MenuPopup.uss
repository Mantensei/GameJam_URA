#menu-overlay {
    position: absolute;
    top: 28px;
    left: 0;
    right: 0;
    bottom: 40px;
    background-color: rgba(0, 0, 0, 0.4);
    justify-content: center;
    align-items: center;
}

#menu-popup {
    align-items: flex-end;
}

#menu-book {
    flex-direction: row;
    width: 285px;
    height: 170px;
}

.menu-cover {
    width: 16px;
    background-color: #6b4226;
    border-width: 1px;
    border-color: #4a2e18;
}

#menu-cover-left {
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
}

#menu-cover-right {
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

#menu-pages {
    flex-grow: 1;
    background-color: #faf5e8;
    padding: 12px 16px;
}

#menu-title {
    -unity-text-align: upper-center;
    font-size: 14px;
    -unity-font-style: bold;
    margin-bottom: 10px;
    letter-spacing: 6px;
}

#menu-columns {
    flex-grow: 1;
    flex-direction: row;
}

.menu-list {
    flex-grow: 1;
    padding-left: 6px;
    padding-right: 6px;
}

.menu-item {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
}

.menu-item-name {
    font-size: 7px;
    flex-shrink: 0;
    white-space: nowrap;
}

.menu-item-price {
    font-size: 7px;
    margin-left: auto;
    flex-shrink: 0;
}

#menu-divider {
    width: 1px;
    background-color: #999;
}

#menu-close-btn {
    margin-top: auto;
    -unity-text-align: middle-right;
    font-size: 7px;
    -unity-font-style: bold;
    color: #555;
    padding-right: 8px;
    height: 18px;
}
