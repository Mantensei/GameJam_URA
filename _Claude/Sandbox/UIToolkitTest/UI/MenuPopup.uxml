<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <Style src="MenuPopup.uss" />

    <ui:VisualElement name="menu-overlay">
        <ui:VisualElement name="menu-popup">
            <ui:VisualElement name="menu-book">
                <ui:VisualElement name="menu-cover-left" class="menu-cover" />
                <ui:VisualElement name="menu-pages">
                    <ui:Label name="menu-title" text="MENU" />
                    <ui:VisualElement name="menu-columns">
                        <ui:VisualElement class="menu-list menu-list-left">
                            <ui:VisualElement class="menu-item">
                                <ui:Label class="menu-item-name" text="・焼き魚定食" />
                                <ui:Label class="menu-item-price" text="¥300" />
                            </ui:VisualElement>
                            <ui:VisualElement class="menu-item">
                                <ui:Label class="menu-item-name" text="・生姜焼き定食" />
                                <ui:Label class="menu-item-price" text="¥300" />
                            </ui:VisualElement>
                            <ui:VisualElement class="menu-item">
                                <ui:Label class="menu-item-name" text="・カレー" />
                                <ui:Label class="menu-item-price" text="¥300" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement name="menu-divider" />
                        <ui:VisualElement class="menu-list menu-list-right">
                            <ui:VisualElement class="menu-item">
                                <ui:Label class="menu-item-name" text="・味噌汁" />
                                <ui:Label class="menu-item-price" text="¥300" />
                            </ui:VisualElement>
                            <ui:VisualElement class="menu-item">
                                <ui:Label class="menu-item-name" text="・コーヒー" />
                                <ui:Label class="menu-item-price" text="¥300" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:Label name="menu-close-btn" text="閉じる(Escape)" />
                </ui:VisualElement>
                <ui:VisualElement name="menu-cover-right" class="menu-cover" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
