<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <Style src="MenuPopup.uss" />
    <ui:VisualElement name="menu-overlay" class="popup-overlay" picking-mode="Ignore">
        <ui:VisualElement name="menu-popup" class="popup-box">
            <ui:Label name="menu-title" text="メモ" class="popup-title" />
            <ui:VisualElement name="menu-list-container" class="popup-list" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
